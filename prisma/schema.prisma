generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BillingItem {
  id               String        @id @default(uuid())
  code             String        @default("")
  name             String
  billingRecipient String        @default("")
  type             String        @default("기본운임")
  mergeCriteria    String        @default("name")
  note             String        @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  rates            BillingRate[]

  @@map("NBC_BillingItem")
}

model BillingRate {
  id        String      @id @default(uuid())
  itemId    String
  validFrom String
  validTo   String?
  amount    Int         @default(0)
  note      String      @default("")
  createdAt DateTime    @default(now())
  item      BillingItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("NBC_BillingRate")
}

model GSSettlement {
  id      String   @id @default(uuid())
  date    String
  code    String
  name    String?
  qty     Decimal  @db.Decimal(11, 2)
  weight  Decimal  @db.Decimal(11, 2)
  amount  Int      @default(0)
  remarks String?  @default("")
  modDate DateTime @default(now())

  @@unique([date, code], name: "GS_UNIQUE")
  @@map("NBC_GSSettlement")
}

model GSSummary {
  id          String   @id @default(uuid())
  startDate   String
  endDate     String
  weekday     Int      @default(0)
  saturday    Int      @default(0)
  sunday      Int      @default(0)
  extraTrucks Int      @default(0)
  totalAmount Int      @default(0)
  dates       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([startDate, endDate], name: "GS_SUMMARY_UNIQUE")
  @@map("NBC_GSSummary")
}

model DailySummary {
  id        String             @id @default(uuid())
  startDate String
  endDate   String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  items     DailySummaryItem[]

  @@unique([startDate, endDate], name: "DAILY_SUMMARY_UNIQUE")
  @@map("NBC_DailySummary")
}

model DailySummaryItem {
  id            String       @id @default(uuid())
  summaryId     String
  placeName     String
  deliveryDays  Int          @default(0)
  totalAmount   Int          @default(0)
  deliveryDates String[]
  summary       DailySummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@map("NBC_DailySummaryItem")
}

model EmergencySettlement {
  id        String   @id @default(uuid())
  startDate String
  endDate   String
  name      String
  chung     String   @default("")
  count     Int      @default(0)
  rate      Int      @default(0)
  total     Int      @default(0)
  dates     String[]
  createdAt DateTime @default(now())

  @@unique([startDate, endDate, name], name: "EMERG_UNIQUE")
  @@map("NBC_EmergencySettlement")
}

model InquirySettlement {
  id        String   @id @default(uuid())
  startDate String
  endDate   String
  date      String
  name      String
  so        String
  nap       String
  ton       String
  kum       Int      @default(0)
  yo        String
  chung     String
  un        Int      @default(0)
  memo      String
  createdAt DateTime @default(now())

  @@unique([startDate, endDate, date, name, so, nap, kum], name: "INQUIRY_UNIQUE")
  @@map("NBC_InquirySettlement")
}

model EmergencyRate {
  name      String   @id
  rate      Int      @default(0)
  chung     String   @default("")
  updatedAt DateTime @updatedAt

  @@map("NBC_EmergencyRate")
}

model FixedSettlement {
  id               String   @id @default(uuid())
  name             String
  billingRecipient String   @default("")
  amount           Int      @default(0)
  count            Int      @default(0)
  rate             Int      @default(0)
  note             String?
  createdAt        DateTime @default(now())

  @@map("NBC_FixedSettlement")
}

model Config {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("NBC_Config")
}

model MonthlyClosing {
  id        String   @id @default(uuid())
  startDate String
  endDate   String
  data      Json
  closedAt  DateTime @default(now())

  @@unique([startDate, endDate], name: "CLOSING_UNIQUE")
  @@map("NBC_MonthlyClosing")
}
